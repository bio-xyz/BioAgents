  "@type": "bibo:AcademicArticle",
  "dcterms:title": "Through synapses to spatial memory maps via a topological model",
  "dcterms:creator": [
    {
      "@id": "https://orcid.org/0000-0003-0000-0000",
      "@type": "foaf:Person",
      "foaf:name": "Yuri Dabaghian"
