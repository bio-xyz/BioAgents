      "@id": "section-1",
      "@type": "fabio:Section",
      "dcterms:title": "Introduction",
      "fabio:hasContent": "The introduction discusses various neurophysiological functions and the role of synaptic connections in cognitive mapping."
    },
    {
      "@id": "section-2",
      "@type": "fabio:Section",
      "dcterms:title": "Methods",
      "fabio:hasContent": "This section details the computational algorithms and experimental setups used to simulate the hippocampal place cell networks."
    },
    {
      "@id": "section-3",
      "@type": "fabio:Section",
      "dcterms:title": "Results",
      "fabio:hasContent": "Key findings regarding synaptic probability and spatial learning are presented, including statistical models and simulation outcomes."
    },
