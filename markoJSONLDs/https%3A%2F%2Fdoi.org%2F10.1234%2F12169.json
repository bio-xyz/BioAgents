  "@type": "bibo:AcademicArticle",
  "dcterms:title": "P110: A Peptide Targeting Mitochondrial Dysfunction in Neurodegenerative Diseases",
  "dcterms:creator": [
    {
      "@id": "https://orcid.org/e8cee0d4-2a80-4740-8c49-e05781f1a83d",
      "@type": "foaf:Person",
      "foaf:name": "Research Team"
    }
  ],
  "dcterms:abstract": "P110 is a therapeutic peptide targeting mitochondrial dysfunction by inhibiting pathological mitochondrial fragmentation. It has shown neuroprotective benefits in preclinical models through restoring mitochondrial homeostasis.",
  "schema:datePublished": "2019-10-08",
  "schema:keywords": [
    "mitochondrial dysfunction",
    "neurodegeneration",
    "P110 peptide",
    "Drp1",
    "Alzheimer's disease",
    "Huntington's disease"
  ],
  "fabio:hasPublicationVenue": {
    "@id": "https://alzdiscovery.org",
    "@type": "fabio:Journal",
    "schema:name": "Cognitive Vitality Reports"
  },
  "fabio:hasPart": [
    {
      "@id": "section1",
      "@type": "fabio:Section",
      "dcterms:title": "Evidence Summary",
      "fabio:hasContent": "Restores mitochondrial homeostasis in preclinical models by inhibiting pathological mitochondrial fragmentation."
    },
    {
      "@id": "section2",
      "@type": "fabio:Section",
      "dcterms:title": "Neuroprotective Benefit",
      "fabio:hasContent": "P110 restores mitochondrial function, improves autophagic flux, and reduces neuroinflammation in preclinical models."
    },
    {
      "@id": "section3",
      "@type": "fabio:Section",
      "dcterms:title": "Aging and Related Health Concerns",
      "fabio:hasContent": "Excessive mitochondrial fragmentation is associated with cardiovascular disease and diabetes. P110 could improve mitochondrial homeostasis."
    }
  ],
