  },
  "fabio:hasPart": [
    {
      "@id": "sec-introduction",
      "@type": "fabio:Section",
      "dcterms:title": "Introduction",
      "fabio:hasContent": "Takotsubo cardiomyopathy (TTC) is an acute syndrome characterized by reversible ventricular dysfunction in the absence of significant coronary artery disease."
    },
    {
      "@id": "sec-case-report",
      "@type": "fabio:Section",
      "dcterms:title": "Case Report",
      "fabio:hasContent": "A 54-year-old Korean man presented with a month-long history of cough and yellowish sputum, an 8kg weight loss over the course of three months, and Modified Medical Research Council Dyspnea Scale grade 1 dyspnea."
    },
    {
      "@id": "sec-discussion",
      "@type": "fabio:Section",
      "dcterms:title": "Discussion",
      "fabio:hasContent": "The Mayo Clinic Criteria are the most widely applied criteria for TTC diagnosis, including several etiological perspectives."
    }
  ],
