  "dcterms:abstract": "PTI-00703 shows promise in preclinical models for preventing and dissolving plaques and tangles, though no clinical efficacy and safety data for humans exist. Research using cat's claw, a primary component, illustrates neuroprotective benefits in animals.",
  "schema:datePublished": "2023-09-01",
  "schema:keywords": [
    "PTI-00703",
    "cat's claw",
    "neuroprotection",
    "plaque reduction",
    "preclinical research"
  ],
  "fabio:hasPublicationVenue": {
    "@id": "https://doi.org/10.1234/journal",
    "@type": "fabio:Journal",
    "schema:name": "Alzheimer's Drug Discovery Foundation Reports"
  },
  "fabio:hasPart": [
    {
      "@id": "sec1",
      "@type": "fabio:Section",
      "dcterms:title": "Evidence Summary",
      "fabio:hasContent": "PTI-00703 prevents the formation and dissolution of plaques and tangles in preclinical models, with no human data available."
    },
    {
      "@id": "sec2",
      "@type": "fabio:Section",
      "dcterms:title": "Neuroprotective Benefit",
      "fabio:hasContent": "Preclinical studies demonstrate inhibition of plaque and tangle formation, reduced astrocytosis and microgliosis, and improved memory in mice."
    },
    {
      "@id": "sec3",
      "@type": "fabio:Section",
      "dcterms:title": "Safety",
      "fabio:hasContent": "No toxicity data for PTI-00703. Reported adverse effects of cat's claw include gastritis, headache, vomiting, and dizziness, similar to placebo rates."
    }
  ],
