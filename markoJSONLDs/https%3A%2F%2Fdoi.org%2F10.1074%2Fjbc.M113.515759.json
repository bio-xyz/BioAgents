  "dcterms:abstract": "Hereditary cystatin C amyloid angiopathy involves the L68Q variant of cystatin C which aggregates in individuals with HCCAA, potentially affecting fertility by forming aggregates in reproductive systems.",
  "schema:datePublished": "2014-03-14",
  "schema:keywords": [
    "cystatin C",
    "L68Q variant",
    "amyloid",
    "male infertility",
    "HCCAA"
  ],
  "fabio:hasPublicationVenue": {
    "@id": "https://doi.org/10.1074/jbc",
    "@type": "fabio:Journal",
    "schema:name": "Journal of Biological Chemistry"
  },
  "fabio:hasPart": [
    {
      "@id": "sec1",
      "@type": "fabio:Section",
      "dcterms:title": "Introduction",
      "fabio:hasContent": "The introduction explains the significance of cystatin C variant L68Q in hereditary amyloidosis and its implications for fertility."
    },
    {
      "@id": "sec2",
      "@type": "fabio:Section",
      "dcterms:title": "Results",
      "fabio:hasContent": "Describes the effects of L68Q variant on fertility in transgenic mice, highlighting abnormalities in sperm function and epididymal fluid composition."
    },
    {
      "@id": "sec3",
      "@type": "fabio:Section",
      "dcterms:title": "Discussion",
      "fabio:hasContent": "The discussion elaborates on the findings and suggests possible mechanisms by which amyloid formation due to L68Q variant can lead to infertility."
    }
  ],
