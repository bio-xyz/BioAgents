  "@id": "https://doi.org/10.1038/s41598-018-36807-0",
  "@type": "bibo:AcademicArticle",
  "dcterms:title": "Through synapses to spatial memory maps via a topological model",
  "dcterms:creator": [
    {
      "@id": "https://orcid.org/0000-0000-0000-0000",
      "@type": "foaf:Person",
      "foaf:name": "Yuri Dabaghian"
    }
  ],
  "dcterms:abstract": "Various neurophysiological and cognitive functions are based on transferring information between spiking neurons via a complex system of synaptic connections. In particular, the capacity of presynaptic inputs to influence the postsynaptic outputs—the efficacy of the synapses—plays a principal role in all aspects of hippocampal neurophysiology.",
  "schema:datePublished": "2019-01-24",
  "schema:keywords": [
    "Neuroscience",
    "Topology",
    "Memory",
    "Synapses",
    "Hippocampal neurophysiology"
  ],
  "fabio:hasPublicationVenue": {
    "@id": "https://www.nature.com/srep/",
    "@type": "fabio:Journal",
    "schema:name": "Scientific Reports"
  },
  "fabio:hasPart": [
    {
      "@id": "s1",
      "@type": "fabio:Section",
      "dcterms:title": "Introduction",
      "fabio:hasContent": "The location-specific spiking activity of the hippocampal neurons, known as place cells, gives rise to an internalized representation of space—a cognitive map."
    },
    {
      "@id": "s2",
      "@type": "fabio:Section",
      "dcterms:title": "Methods",
      "fabio:hasContent": "The computational algorithms used in this study were described in referenced works."
    },
    {
      "@id": "s3",
      "@type": "fabio:Section",
      "dcterms:title": "Results",
      "fabio:hasContent": "Learning times depend on the synaptic strength and how effectively synaptic connections form cognitive maps."
    },
    {
      "@id": "s4",
      "@type": "fabio:Section",
      "dcterms:title": "Discussion",
      "fabio:hasContent": "Numerous observations point out that deteriorations of synapses often accompany memory deficiencies."
    }
  ],
