    }
  ],
  "dcterms:abstract": "Mitochondrial dynamics, involving a balance between fusion and fission, regulates mitochondrial quality and number. We observed that Drp1 interaction with Fis1 is significantly increased in Aβ-treated neurons and AD patient-derived fibroblasts. P110 peptide, which inhibits Drp1/Fis1 interaction, reduces mitochondrial dysfunction and cognitive decline, suggesting a therapeutic potential in AD.",
  "schema:datePublished": "2017-12-22",
  "schema:keywords": [
    "mitochondrial dysfunction",
    "Alzheimer's disease",
    "Drp1",
    "Fis1",
    "P110",
    "bioenergetic failure"
  ],
  "fabio:hasPublicationVenue": {
    "@id": "https://doi.org/10.1234/venue",
    "@type": "fabio:Journal",
    "schema:name": "Oncotarget"
  },
  "fabio:hasPart": [
    {
      "@id": "introduction",
      "@type": "fabio:Section",
      "dcterms:title": "Introduction",
      "fabio:hasContent": "Alzheimer's disease (AD) is characterized by neurodegeneration and cognitive decline. Mitochondrial dysfunction plays a crucial role in AD pathogenesis."
    },
    {
      "@id": "methods",
      "@type": "fabio:Section",
      "dcterms:title": "Materials and Methods",
      "fabio:hasContent": "Description of cell culture, peptide treatments, and assays used to evaluate mitochondrial health and cognitive function."
    },
    {
      "@id": "results",
      "@type": "fabio:Section",
      "dcterms:title": "Results",
      "fabio:hasContent": "Drp1/Fis1 interaction increased in AD models, causing mitochondrial defects and cognitive decline. P110 treatment reduced these effects."
    },
    {
      "@id": "discussion",
      "@type": "fabio:Section",
      "dcterms:title": "Discussion",
      "fabio:hasContent": "The study concludes that Drp1/Fis1 interaction is a significant factor in AD, and inhibiting it with P110 has therapeutic potential."
    }
  ],
