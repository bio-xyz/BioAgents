  "@type": "schema:ScholarlyArticle",
  "dcterms:title": "Drp1/Fis1 Interaction Mediates Mitochondrial Dysfunction, Bioenergetic Failure and Cognitive Decline in Alzheimer's Disease",
  "dcterms:creator": [
    {
      "@id": "https://orcid.org/0000-0002-1234-5678",
