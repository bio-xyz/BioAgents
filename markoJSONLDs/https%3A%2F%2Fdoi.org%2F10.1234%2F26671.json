  "dcterms:abstract": "There is a critical need for alternatives to native veins or arteries for vascular surgery. This study presents the use of human fibroblasts to construct Tissue Engineered Blood Vessels (TEBVs) for arterial bypass grafting. These vessels demonstrated mechanical properties similar to human blood vessels and were successfully integrated in animal models.",
  "schema:datePublished": "2006-03-01",
  "schema:keywords": [
    "Tissue engineering",
    "Blood vessels",
    "Arterial revascularization",
    "Biomaterials"
  ],
  "fabio:hasPublicationVenue": {
    "@id": "https://doi.org/10.1234/nm",
    "@type": "fabio:Journal",
    "schema:name": "Nature Medicine"
  },
  "fabio:hasPart": [
    {
      "@id": "#methods",
      "@type": "fabio:Section",
      "dcterms:title": "Methods",
      "fabio:hasContent": "Human skin fibroblasts were extracted and cultured for sheet production. The TEBV was assembled using these sheets and evaluated for strength and integration."
    },
    {
      "@id": "#results",
      "@type": "fabio:Section",
      "dcterms:title": "Results",
      "fabio:hasContent": "The TEBVs demonstrated positive healing characteristics and stability over several months in animal models."
    }
  ],
