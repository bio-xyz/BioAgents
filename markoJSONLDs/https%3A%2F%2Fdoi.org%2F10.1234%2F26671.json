  "@type": "bibo:AcademicArticle",
  "dcterms:title": "Human Tissue Engineered Blood Vessel for Adult Arterial Revascularization",
  "dcterms:creator": [
    {
      "@id": "https://orcid.org/0000-0001-2345-6789",
