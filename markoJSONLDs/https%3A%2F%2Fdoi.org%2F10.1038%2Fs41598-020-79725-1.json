  "@id": "https://doi.org/10.1038/s41598-020-79725-1",
  "@type": "bibo:AcademicArticle",
  "dcterms:title": "In vitro comparison of major memory-support dietary supplements for their effectiveness in reduction/inhibition of beta-amyloid protein fibrils and tau protein tangles: key primary targets for memory loss",
  "dcterms:creator": [
    {
      "@id": "https://orcid.org/0000-0002-1825-0097",
      "@type": "foaf:Person",
      "foaf:name": "Alan D. Snow"
    },
    {
      "@id": "https://orcid.org/0000-0003-1825-0100",
