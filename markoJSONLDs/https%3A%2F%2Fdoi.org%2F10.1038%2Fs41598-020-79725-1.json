      "foaf:name": "Rudolph E. Tanzi"
    },
    {
      "@id": "https://orcid.org/0000-0003-1825-0102",
      "@type": "foaf:Person",
      "foaf:name": "Thomas Lake"
    }
  ],
  "dcterms:abstract": "This study examines the effects of 21 memory-support dietary supplements for their ability to reduce or inhibit beta-amyloid protein fibrils and tau protein tangles, primary targets for memory loss. The results indicate that Percepta was the most effective in disrupting these protein aggregations, suggesting its potential role in memory support.",
  "schema:datePublished": "2021-02-15",
  "schema:keywords": [
    "memory-support",
    "beta-amyloid",
    "tau protein",
    "dietary supplements",
    "neuroinflammation"
  ],
  "fabio:hasPublicationVenue": {
    "@id": "https://www.nature.com/srep/",
    "@type": "fabio:Journal",
    "schema:name": "Scientific Reports"
  },
  "fabio:hasPart": [
    {
      "@id": "section1",
      "@type": "fabio:Section",
      "dcterms:title": "Introduction",
      "fabio:hasContent": "The introduction provides the background on how beta-amyloid and tau protein contribute to memory loss and sets the stage for evaluating dietary supplements in combating these processes."
    },
    {
      "@id": "section2",
      "@type": "fabio:Section",
      "dcterms:title": "Methods",
      "fabio:hasContent": "This section details the in vitro methods used to measure the effectiveness of memory-support dietary supplements in inhibiting or disrupting beta-amyloid and tau aggregations."
    },
    {
      "@id": "section3",
      "@type": "fabio:Section",
      "dcterms:title": "Results",
      "fabio:hasContent": "The results reveal that Percepta, which contains PTI-00703 cat's claw, was the most potent disruptor of beta-amyloid and tau fibrils among the supplements tested."
    },
    {
      "@id": "section4",
      "@type": "fabio:Section",
      "dcterms:title": "Discussion",
      "fabio:hasContent": "The discussion interprets the findings, emphasizing the potential of specific polyphenols in Percepta for enhancing memory support by targeting key protein aggregations."
    }
  ],
