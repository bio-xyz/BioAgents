    }
  ],
  "dcterms:abstract": "Non-progressive cerebellar ataxias are disorders causing static encephalopathy. The paper reports mutations in PMPCA in 17 patients which lead to abnormal mitochondrial protein processing. These mutations are linked with cerebellar ataxia resembling Friedreich ataxia due to impacts on the function of mitochondrial processing peptidase.",
  "schema:datePublished": "2015-01-01",
  "schema:keywords": [
    "cerebellar ataxia",
    "PMPCA",
    "mitochondrial processing peptidase",
    "non-progressive",
    "mitochondrial protein processing"
  ],
  "fabio:hasPublicationVenue": {
    "@id": "https://doi.org/10.1093/brain",
