  "@type": "bibo:AcademicArticle",
  "dcterms:title": "PMPCA mutations cause abnormal mitochondrial protein processing in patients with non-progressive cerebellar ataxia",
  "dcterms:creator": [
    {
      "@id": "https://orcid.org/0000-0002-1825-0097",
      "@type": "foaf:Person",
      "foaf:name": "Rebekah K. Jobling"
