    "schema:name": "Brain"
  },
  "fabio:hasPart": [
    {
      "@id": "#introduction",
      "@type": "fabio:Section",
      "dcterms:title": "Introduction",
      "fabio:hasContent": "Non-progressive cerebellar ataxias are a rare group of disorders that comprise approximately 10% of static infantile encephalopathy. The report on mutations in PMPCA is key for understanding these conditions."
    },
    {
      "@id": "#methods",
      "@type": "fabio:Section",
      "dcterms:title": "Materials and Methods",
      "fabio:hasContent": "Seventeen patients from four families were included in this study involving clinical and genetic analysis."
    }
  ],
