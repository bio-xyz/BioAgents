  "@id": "https://doi.org/10.1001/jamaneurol.2023.5319",
  "@type": "schema:ScholarlyArticle",
  "dcterms:title": "Diagnostic Accuracy of a Plasma Phosphorylated Tau 217 Immunoassay for Alzheimer Disease Pathology",
  "dcterms:creator": [
    {
      "@id": "https://orcid.org/0000-0001-2345-6789",
      "@type": "foaf:Person",
      "foaf:name": "Nicholas J. Ashton"
    },
    {
      "@id": "https://orcid.org/0000-0002-3456-7890",
      "@type": "foaf:Person",
      "foaf:name": "Kaj Blennow"
    }
  ],
  "dcterms:abstract": "This study evaluates the capability of a commercially available plasma assay targeting p-tau217 in identifying Alzheimer disease (AD) pathology. The findings demonstrate high accuracy in detecting abnormal Aβ and tau pathologies, comparable to CSF measures.",
  "schema:datePublished": "2024-01-22",
  "schema:keywords": [
    "Alzheimer Disease",
    "Plasma Biomarkers",
    "p-tau217 Immunoassay",
    "Diagnostic Accuracy"
  ],
  "fabio:hasPublicationVenue": {
    "@id": "https://doi.org/10.1001/jamaneurol",
    "@type": "fabio:Journal",
    "schema:name": "JAMA Neurology"
  },
  "fabio:hasPart": [
    {
      "@id": "section1",
      "@type": "fabio:Section",
      "dcterms:title": "Methods",
      "fabio:hasContent": "This study included participants from 3 observational cohorts: the Translational Biomarkers in Aging and Dementia (TRIAD), Wisconsin Registry for Alzheimer’s Prevention (WRAP), and the Sant Pau Initiative on Neurodegeneration (SPIN)."
    },
    {
      "@id": "section2",
      "@type": "fabio:Section",
      "dcterms:title": "Results",
      "fabio:hasContent": "The study included 786 participants. The p-tau217 assay demonstrated high accuracy in detecting abnormal amyloid and tau pathologies across cohorts."
    },
    {
      "@id": "section3",
      "@type": "fabio:Section",
      "dcterms:title": "Conclusions",
      "fabio:hasContent": "This study highlights the effectiveness of a commercially available plasma p-tau217 assay in identifying AD pathology."
    }
  ],
