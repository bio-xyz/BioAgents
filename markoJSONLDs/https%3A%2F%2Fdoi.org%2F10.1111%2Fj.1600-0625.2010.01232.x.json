    },
    {
      "@id": "https://orcid.org/99a05bc0-0a21-4aee-a8db-34fd976c19fe",
      "@type": "foaf:Person",
      "foaf:name": "Jodi Speiser"
    }
  ],
  "dcterms:abstract": "To study protection of melanocytes from stress-induced cell death by heme oxygenases during depigmentation and repigmentation in vitiligo, expression of isoforms 1 and 2 was studied in cultured control and patient melanocytes and normal skin explants exposed to UV or bleaching agent 4-TBP. Similarly, expression of heme oxygenase was followed in skin from vitiligo patients before and after PUVA treatment.",
  "schema:datePublished": "2011-06-01",
  "schema:keywords": ["heme oxygenase", "melanocyte", "stress", "ultraviolet"],
  "fabio:hasPublicationVenue": {
    "@id": "https://doi.org/10.1111/journal.pone.0173240",
    "@type": "fabio:Journal",
    "schema:name": "Experimental Dermatology"
  },
  "fabio:hasPart": [
    {
      "@id": "#introduction",
      "@type": "fabio:Section",
      "dcterms:title": "Introduction",
      "fabio:hasContent": "Vitiligo patients present with white skin patches because of progressive loss of melanocytes."
    },
    {
      "@id": "#methods",
      "@type": "fabio:Section",
      "dcterms:title": "Materials and Methods",
      "fabio:hasContent": "Biopsies were obtained from nine patients > 12 years of age with vitiligo both before and after PUVA treatment."
    },
    {
      "@id": "#results",
      "@type": "fabio:Section",
      "dcterms:title": "Results",
      "fabio:hasContent": "HO-1 expression is upregulated in skin from vitiligo patients following PUVA treatment."
    },
    {
      "@id": "#discussion",
      "@type": "fabio:Section",
      "dcterms:title": "Discussion",
      "fabio:hasContent": "A cytoprotective role is well established for HO-1, yet studies often describe its function without assessing HO-2."
    }
  ],
