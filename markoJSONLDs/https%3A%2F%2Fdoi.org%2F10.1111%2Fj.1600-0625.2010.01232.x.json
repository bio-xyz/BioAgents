  "@type": "bibo:AcademicArticle",
  "dcterms:title": "Heme oxygenase-1 expression protects melanocytes from stress-induced cell death: implications for vitiligo",
  "dcterms:creator": [
    {
      "@id": "https://orcid.org/99a05bc0-0a21-4aee-a8db-34fd976c19fc",
