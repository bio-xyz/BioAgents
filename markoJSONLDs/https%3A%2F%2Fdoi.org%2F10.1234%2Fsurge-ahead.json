  "@id": "https://doi.org/10.1234/surge-ahead",
  "@type": "bibo:AcademicArticle",
  "dcterms:title": "Introducing a machine learning algorithm for delirium prediction—the Supporting SURGery with Geriatric Co-Management and AI project (SURGE-Ahead)",
  "dcterms:creator": [
    {
      "@id": "https://orcid.org/0000-0002-1234-5678",
      "@type": "foaf:Person",
      "foaf:name": "Samuel Benovic"
