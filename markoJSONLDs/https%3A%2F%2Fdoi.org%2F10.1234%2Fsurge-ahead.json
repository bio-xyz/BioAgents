    }
  ],
  "dcterms:abstract": "In this study, we introduce an AI model for predicting post-operative delirium (POD) in older patients. The model, developed using the PAWEL dataset, involves machine learning techniques for prognosis based on relevant clinical features.",
  "schema:datePublished": "2023-10-19",
  "schema:keywords": [
    "delirium prediction",
    "machine learning",
    "support vector machine",
    "post-operative delirium",
    "explainable artificial intelligence (AI)",
    "older people"
  ],
  "fabio:hasPublicationVenue": {
    "@id": "https://doi.org/10.xxxx/ageandageing",
    "@type": "fabio:Journal",
    "schema:name": "Age and Ageing"
  },
  "fabio:hasPart": [
    {
      "@id": "introduction",
      "@type": "fabio:Section",
      "dcterms:title": "Introduction",
      "fabio:hasContent": "Post-operative delirium is a common complication among elderly surgical patients. This section provides background on the prevalence and impact of POD."
    },
    {
      "@id": "methods",
      "@type": "fabio:Section",
      "dcterms:title": "Methods",
      "fabio:hasContent": "The model was trained on data from the PAWEL study, using logistic regression and support vector machines to derive predictions from clinical data."
    },
    {
      "@id": "results",
      "@type": "fabio:Section",
      "dcterms:title": "Results",
      "fabio:hasContent": "Our model achieved an ROC AUC of 0.82 in training and 0.81 in testing, demonstrating robust predictive performance."
    },
    {
      "@id": "discussion",
      "@type": "fabio:Section",
      "dcterms:title": "Discussion",
      "fabio:hasContent": "The study discusses the implications of using machine learning in pre-surgical assessments and the potential for reducing POD incidence."
    }
  ],
