# Non-secret env for local kind cluster. Copy to config.env and adjust.
USE_JOB_QUEUE=true
NODE_ENV=development

# Concurrency per worker — small for local
CHAT_QUEUE_CONCURRENCY=2
DEEP_RESEARCH_QUEUE_CONCURRENCY=1
FILE_PROCESS_CONCURRENCY=2
PAPER_GENERATION_CONCURRENCY=1

# LLM provider routing
REPLY_LLM_PROVIDER=openai
REPLY_LLM_MODEL=gpt-5.4
HYP_LLM_PROVIDER=openai
HYP_LLM_MODEL=gpt-5.4
PLANNING_LLM_PROVIDER=openai
PLANNING_LLM_MODEL=gpt-5.4
STRUCTURED_LLM_PROVIDER=openai
STRUCTURED_LLM_MODEL=gpt-5.4
DISCOVERY_LLM_PROVIDER=openai
DISCOVERY_LLM_MODEL=gpt-5.4
REFLECTION_LLM_PROVIDER=openai
REFLECTION_LLM_MODEL=gpt-5.4
PAPER_GEN_LLM_PROVIDER=openai
PAPER_GEN_LLM_MODEL=gpt-5.4
CONTINUE_RESEARCH_LLM_PROVIDER=openai
CONTINUE_RESEARCH_LLM_MODEL=gpt-5.4

CHAT_AGENT_MODEL=claude-sonnet-4-6
CHAT_AGENT_MAX_TOOL_CALLS=10
CHAT_AGENT_MAX_TOKENS=4096
CHAT_TOOL_TIMEOUT_MS=30000

EMBEDDING_PROVIDER=openai
TEXT_EMBEDDING_MODEL=text-embedding-3-large
