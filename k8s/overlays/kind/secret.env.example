# Secret env for local kind cluster. Copy to secret.env and fill in.
# secret.env is gitignored.

REDIS_URL=rediss://default:PASSWORD@HOST:PORT
REDIS_KEDA_ADDRESS=HOST:PORT
REDIS_KEDA_PASSWORD=PASSWORD

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_FULL_URL=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
COHERE_API_KEY=

BIOAGENTS_SECRET=
AUTH_MODE=none

EDISON_API_URL=
EDISON_API_KEY=
BIO_LIT_AGENT_API_URL=
BIO_LIT_AGENT_API_KEY=
DATA_ANALYSIS_API_URL=
DATA_ANALYSIS_API_KEY=
OPENSCHOLAR_API_URL=

STORAGE_PROVIDER=s3
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
